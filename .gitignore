# ======================================================================
#  OpenFOAM case .gitignore
#  只跟踪必要的输入文件 (system/, constant/, 0/, Allrun, Allclean ...)
#  忽略所有运行产物 (时间目录, 分解目录, 日志, 后处理结果)
# ======================================================================

# --- 时间结果目录 ---
# 运行时的 0/ 由 Allrun 从 0.orig 重新生成 (0.orig 才是版本控制的初始场)
/0/
[1-9]*/
0.[0-9]*/
-[0-9]*/

# --- 并行分解 / 重构产物 ---
processor*/

# --- 求解器与工具日志 ---
log.*
*.log
logs/

# --- 后处理输出 ---
postProcessing/
VTK/
*.foam
*.OpenFOAM

# --- 网格转换 / 中间产物 (blockMesh 可由 blockMeshDict 重新生成) ---
constant/polyMesh/*
# 若希望随仓库分发网格, 取消下一行注释保留 blockMeshDict 生成的网格:
#!constant/polyMesh/

# --- 杂项 ---
*~
.*.swp
core
*.tar.gz
