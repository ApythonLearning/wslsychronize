FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

// 模板初始温度; setFields 会覆盖 (默认 298K, 点火核 2000K)
internalField   uniform 298;

boundaryField
{
    walls
    {
        type            zeroGradient;
    }
}


