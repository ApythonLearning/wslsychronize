FoamFile { version 2.0; format ascii; class dictionary; object controlDict; }

application     foamRun;          // OF12: reactingFoam removed, use foamRun ...
solver          multicomponentFluid;   // ... with the multicomponentFluid module
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         0.002;          // 2 ms

deltaT          2e-8;           // initial dt; adjusted by CFL
adjustTimeStep  yes;
maxCo           0.15;           // keep reactive-energy updates conservative
maxDeltaT       1e-7;

writeControl    adjustableRunTime;
writeInterval   5e-4;           // write every 0.5 ms (= 30 outputs total)
purgeWrite      0;
writeFormat     binary;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   8;
runTimeModifiable yes;

functions
{
    // live ignition/quench monitor: max of T, OH, H2O every 20 steps
    cellMax
    {
        type            volFieldValue;
        libs            ("libfieldFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   20;
        writeFields     false;
        select          all;
        operation       max;
        fields          (T OH H2O);
    }
}
