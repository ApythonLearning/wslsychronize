/*
  Set initial fields (generated by Allrun for 10.0 vol% H2 in O2):
  - Outer domain: unburned H2-O2 mixture, T=298K
  - Ignition kernel (r < 5mm): hot combustion products + OH seed at T=2800K
  phi = 0.056
*/
FoamFile { version 2.0; format ascii; class dictionary; object setFieldsDict; }

// ---------- unburned mixture ----------
defaultFieldValues
(
    volScalarFieldValue T       298.0
    volScalarFieldValue p        101325.0
    volVectorFieldValue U       (0 0 0)
    volScalarFieldValue H2      0.0070
    volScalarFieldValue O2      0.9930
    volScalarFieldValue N2      0.0
    volScalarFieldValue H2O     0.0
    volScalarFieldValue H       0.0
    volScalarFieldValue O       0.0
    volScalarFieldValue OH      0.0
    volScalarFieldValue HO2     0.0
    volScalarFieldValue H2O2    0.0
);

regions
(
    // Ignition kernel: hot products + OH seed (T=2800K, r < 5mm)
    sphereToCell
    {
        centre  (0 0 0);
        radius  0.005;
        fieldValues
        (
            volScalarFieldValue T       2800.0
            volScalarFieldValue H2      0.0000
            volScalarFieldValue O2      0.9379
            volScalarFieldValue N2      0.0
            volScalarFieldValue H2O     0.0421
            volScalarFieldValue H       0.0
            volScalarFieldValue O       0.0
            volScalarFieldValue OH      0.0200
            volScalarFieldValue HO2     0.0
            volScalarFieldValue H2O2    0.0
        );
    }
);
